{
	"compilerOptions": {
		"target": "ES2020",
		"useDefineForClassFields": true,
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"skipLibCheck": true,
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "react-jsx",
		"strict": true,
		"forceConsistentCasingInFileNames": true,
		"esModuleInterop": true,
		"baseUrl": ".",
		"paths": {
			"rtdf/theme": ["../../packages/rtdf/src/lib/theme/index.ts"],
			"rtdf/types": ["../../packages/rtdf/src/lib/types/index.ts"],
			"rtdf/utils": ["../../packages/rtdf/src/lib/components/utils/index.ts"],
			"rtdf/*": ["../../packages/rtdf/src/lib/*"]
		}
	},
	"include": ["src"],
	"references": [{ "path": "./tsconfig.node.json" }]
}
