{
	"name": "create-rtdf",
	"version": "0.0.1",
	"description": "A CLI for creating new RTDF React projects",
	"bin": {
		"create-rtdf": "dist/index.js"
	},
	"scripts": {
		"build": "rollup -c",
		"bt": "rollup -c && bun run dist/index.js",
		"test": "bun run build"
	},
	"files": [
		"dist/**",
		"templates/**",
		"snippet/**"
	],
	"engines": {
		"node": ">=18.0.0"
	},
	"dependencies": {
		"@clack/prompts": "^0.11.0",
		"fs-extra": "^11.3.3",
		"kleur": "^4.1.5",
		"minimist": "^1.2.8",
		"pacote": "^21.0.4"
	},
	"devDependencies": {
		"@rollup/plugin-terser": "^0.4.4",
		"rollup": "^4.56.0"
	},
	"keywords": [
		"react",
		"vite",
		"tailwind",
		"typescript",
		"rtdf",
		"cli",
		"mobile",
		"iconify"
	],
	"author": "any-tdf",
	"funding": "https://rtdf.dev?fund",
	"license": "MIT",
	"type": "module",
	"homepage": "https://github.com/any-tdf/rtdf/blob/main/packages/create/README.md",
	"repository": {
		"type": "git",
		"url": "https://github.com/any-tdf/rtdf"
	},
	"bugs": {
		"url": "https://github.com/any-tdf/rtdf/issues?q=is:issue+is:open+create"
	}
}
