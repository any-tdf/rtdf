		"build": "tsc -b && vite build",
		"build:lib": "vite build --config vite.lib.config.ts && mkdir -p dist/fonts && cp public/fonts/Trueno.otf dist/fonts/Trueno.otf && cp src/index.css dist/style.css && tsc -p tsconfig.lib.json && bun ../../../scripts/prepare-framework-dist.mjs dist",
